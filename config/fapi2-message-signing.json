{
  "description": "Vouch {VERSION} FAPI 2.0 Message Signing",
  "variant": {
    "openid": "openid_connect",
    "client_auth_type": "private_key_jwt",
    "sender_constrain": "dpop",
    "fapi_profile": "plain_fapi",
    "fapi_request_method": "signed_non_repudiation",
    "fapi_response_mode": "plain_response",
    "authorization_request_type": "simple"
  },
  "client_alias": "vouch-fapi2-ms",
  "server": {
    "discoveryUrl": "{BASEURL}/.well-known/openid-configuration"
  },
  "client": {
    "client_id": "{CLIENT_ID}",
    "jwks": {CLIENT_JWKS},
    "scope": "openid email",
    "registration_access_token": "{CLIENT_REG_TOKEN}"
  },
  "resource": {
    "resourceUrl": "{BASEURL}/oauth/userinfo"
  },
  "client2": {
    "client_id": "{CLIENT2_ID}",
    "jwks": {CLIENT2_JWKS},
    "scope": "openid email",
    "registration_access_token": "{CLIENT2_REG_TOKEN}"
  },
  "browser": [
    {
      "match": "{BASEURL}/oauth/authorize*",
      "tasks": [
        {
          "task": "Login",
          "optional": true,
          "match": "{BASEURL}/login*",
          "commands": [
            ["click", "id", "cert-login"]
          ]
        },
        {
          "task": "Verify Complete",
          "optional": true,
          "match": "*/test/*/callback*",
          "commands": [
            ["wait", "id", "submission_complete", 10]
          ]
        }
      ]
    }
  ],
  "override": {
    "fapi2-security-profile-final-user-rejects-authentication": {
      "browser": [
        {
          "match": "{BASEURL}/oauth/authorize*",
          "tasks": [
            {
              "task": "Deny Login",
              "optional": true,
              "match": "{BASEURL}/login*",
              "commands": [
                ["click", "id", "cert-deny"]
              ]
            },
            {
              "task": "Verify Complete",
              "optional": true,
              "match": "*/test/*/callback*",
              "commands": [
                ["wait", "id", "submission_complete", 10]
              ]
            }
          ]
        }
      ]
    }
  }
}
