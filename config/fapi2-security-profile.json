{
  "description": "Vouch {VERSION} FAPI 2.0 Security Profile",
  "variant": {
    "openid": "openid_connect",
    "client_auth_type": "private_key_jwt",
    "sender_constrain": "dpop",
    "fapi_profile": "plain_fapi"
  },
  "client_alias": "vouch-fapi2",
  "server": {
    "discoveryUrl": "{BASEURL}/.well-known/openid-configuration"
  },
  "client": {
    "client_id": "{CLIENT_ID}",
    "jwks": {CLIENT_JWKS},
    "scope": "openid",
    "registration_access_token": "{CLIENT_REG_TOKEN}"
  },
  "resource": {
    "resourceUrl": "{BASEURL}/oauth/userinfo"
  },
  "client2": {
    "client_id": "{CLIENT2_ID}",
    "jwks": {CLIENT2_JWKS},
    "scope": "openid",
    "registration_access_token": "{CLIENT2_REG_TOKEN}"
  },
  "browser": [
    {
      "match": "{BASEURL}/oauth/authorize*",
      "tasks": [
        {
          "task": "Login",
          "optional": true,
          "match": "{BASEURL}/login*",
          "commands": [
            ["click", "id", "cert-login"]
          ]
        },
        {
          "task": "Verify Complete",
          "optional": true,
          "match": "*/test/*/callback*",
          "commands": [
            ["wait", "id", "submission_complete", 10]
          ]
        }
      ]
    }
  ]
}
